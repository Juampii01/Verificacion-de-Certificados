# ----- Supabase -----
# En Supabase: Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_anon_key_publica

# La service_role key es SECRETA. Solo se usa en el servidor. Nunca la pongas
# en variables NEXT_PUBLIC_ ni la subas a un repo público.
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key_secreta

# ----- Config del sistema -----
# URL pública donde vive el verificador (para armar el QR).
VERIFY_BASE_URL=https://verify.govbidder.net

# Contraseña para entrar al panel admin y poder crear certificados.
ADMIN_TOKEN=cambia_esto_por_algo_largo_y_secreto

# ----- Resend (envío de emails) -----
# En Resend: API Keys -> Create API Key.
RESEND_API_KEY=tu_resend_api_key_secreta

# Remitente de los emails de certificado. El dominio debe estar verificado en Resend
# (Project -> Domains). Ojo: verificar el dominio exacto, un subdominio verificado
# (ej. send.govbidder.net) no habilita el dominio raíz (govbidder.net) ni viceversa.
RESEND_FROM=certificados@send.govbidder.net
